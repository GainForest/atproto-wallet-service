# ============================================================================
# atproto-wallet-service — Environment Variables
# ============================================================================

# Port the service listens on.
WALLET_SERVICE_PORT=3020

# Data directory (sqlite store + root seed file in dev).
WALLET_SERVICE_DATA_DIR=./data/wallet-service

# This service's own DID — the `aud` of every incoming service-auth token.
# In production use did:web on the service's public hostname.
SERVICE_DID=did:web:wallet.example.com

# Admin secret gating operator tooling only (POST /v1/wallet/pregenerate,
# GET /v1/wallet/enrollment/:did). Never sufficient for signing/export.
# Generate with: openssl rand -hex 32
WALLET_SERVICE_ADMIN_SECRET=

# Root seed (KEK derivation + enclave encryption identity).
# Production (spot-safe): set WALLET_SERVICE_ROOT_SEED_SOURCE=dstack-kms to
# fetch the seed from the external dstack KMS via the guest-agent socket at
# every boot — deterministic across instance re-creation, nothing secret on
# the boot disk. Hex + dev-seed-file modes exist for development only.
# WALLET_SERVICE_ROOT_SEED_SOURCE=dstack-kms
# WALLET_SERVICE_KMS_KEY_PATH=wallet-service/root-seed
# WALLET_SERVICE_ROOT_SEED_HEX=
# WALLET_SERVICE_ROOT_SEED_FILE=./data/wallet-service/root-seed
# WALLET_SERVICE_ALLOW_DEV_SEED=1

# PLC directory used to resolve users' DID documents (service-auth).
# PLC_URL=https://plc.directory

# Envelope freshness window in seconds (default 90).
# WALLET_SERVICE_FRESHNESS_SEC=90

# dstack guest-agent socket for attestation quotes + KMS key fetch (in a CVM).
# WALLET_SERVICE_DSTACK_SOCK=/var/run/dstack.sock

# Spot / failover hardening.
# Watch the GCP metadata server for the ~30s spot preemption notice and run
# a controlled shutdown (drain → grace → WAL checkpoint → seed wipe).
# WALLET_SERVICE_PREEMPTION_WATCH=gcp
# Grace period for in-flight requests during shutdown (default 10000 ms;
# keep it well under the 30s preemption window).
# WALLET_SERVICE_SHUTDOWN_GRACE_MS=10000

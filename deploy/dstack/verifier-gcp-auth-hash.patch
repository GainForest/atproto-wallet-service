+/// Compute the Microsoft Authenticode SHA-256 image digest used by GCP's
+/// measured UKI event. The checksum field and certificate table are excluded
+/// according to the PE/COFF Authenticode specification.
+fn authenticode_sha256(path: &Path) -> Result<String> {
+    let data = fs_err::read(path).context("Failed to read GCP UKI disk.raw")?;
+    let pe_offset = pe_u32(&data, 0x3c, "DOS header")? as usize;
+    if pe_u32(&data, pe_offset, "PE signature")? != 0x0000_4550 {
+        bail!("disk.raw has an invalid PE signature");
+    }
+    let coff = pe_offset + 4;
+    let section_count = pe_u16(&data, coff + 2, "section count")? as usize;
+    let optional_size = pe_u16(&data, coff + 16, "optional header size")? as usize;
+    let optional = coff + 20;
+    let pe32_plus = pe_u16(&data, optional, "optional header magic")? == 0x20b;
+    let checksum = optional + 64;
+    let data_dirs = optional + if pe32_plus { 112 } else { 96 };
+    let cert_dir = data_dirs + 4 * 8;
+    let headers_size = pe_u32(&data, optional + 60, "headers size")? as usize;
+    if headers_size > data.len() || checksum + 4 > cert_dir || cert_dir + 8 > headers_size {
+        bail!("disk.raw has invalid PE header offsets");
+    }
+
+    let mut hash = Sha256::new();
+    hash.update(&data[..checksum]);
+    hash.update(&data[checksum + 4..cert_dir]);
+    hash.update(&data[cert_dir + 8..headers_size]);
+
+    let section_table = optional + optional_size;
+    let mut sections = Vec::with_capacity(section_count);
+    for index in 0..section_count {
+        let entry = section_table + index * 40;
+        let size = pe_u32(&data, entry + 16, "section size")? as usize;
+        let offset = pe_u32(&data, entry + 20, "section offset")? as usize;
+        if size > 0 {
+            sections.push((offset, size));
+        }
+    }
+    sections.sort_unstable_by_key(|(offset, _)| *offset);
+    let mut hashed_bytes = headers_size;
+    for (offset, size) in sections {
+        let end = offset.checked_add(size).context("PE section size overflow")?;
+        if offset < data.len() {
+            hash.update(&data[offset..end.min(data.len())]);
+        }
+        hashed_bytes = hashed_bytes.saturating_add(size);
+    }
+
+    let cert_offset = pe_u32(&data, cert_dir, "certificate offset")? as usize;
+    let cert_size = pe_u32(&data, cert_dir + 4, "certificate size")? as usize;
+    if cert_offset > 0 && cert_size > 0 && data.len() > hashed_bytes {
+        let trailing = data.len() - hashed_bytes;
+        if trailing > cert_size {
+            let trailing_len = trailing - cert_size;
+            let end = hashed_bytes
+                .checked_add(trailing_len)
+                .context("PE trailing data overflow")?;
+            if end <= data.len() {
+                hash.update(&data[hashed_bytes..end]);
+            }
+        }
+    }
+    let remainder = data.len() % 8;
+    if remainder != 0 {
+        hash.update(vec![0u8; 8 - remainder]);
+    }
+    Ok(hex::encode(hash.finalize()))
+}

+fn pe_u16(data: &[u8], offset: usize, field: &str) -> Result<u16> {
+    let bytes: [u8; 2] = data
+        .get(offset..offset + 2)
+        .context(format!("PE image is truncated at {field}"))?
+        .try_into()
+        .expect("slice length checked");
+    Ok(u16::from_le_bytes(bytes))
+}
+
+fn pe_u32(data: &[u8], offset: usize, field: &str) -> Result<u32> {
+    let bytes: [u8; 4] = data
+        .get(offset..offset + 4)
+        .context(format!("PE image is truncated at {field}"))?
+        .try_into()
+        .expect("slice length checked");
+    Ok(u32::from_le_bytes(bytes))
+}
+
+fn pe_u64(data: &[u8], offset: usize, field: &str) -> Result<u64> {
+    let bytes: [u8; 8] = data
+        .get(offset..offset + 8)
+        .context(format!("disk image is truncated at {field}"))?
+        .try_into()
+        .expect("slice length checked");
+    Ok(u64::from_le_bytes(bytes))
+}

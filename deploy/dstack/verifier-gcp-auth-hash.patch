+fn gpt_first_partition_offset(path: &Path) -> Result<u64> {
+    const SECTOR_SIZE: u64 = 512;
+    let data = fs_err::read(path).context("Failed to read GCP disk.raw GPT")?;
+    if data.get(512..520) != Some(b"EFI PART") {
+        bail!("disk.raw has an invalid GPT signature");
+    }
+    let entries_lba = pe_u64(&data, 512 + 72, "GPT partition-entry LBA")?;
+    let entry_size = pe_u32(&data, 512 + 84, "GPT partition-entry size")? as u64;
+    if entry_size < 40 {
+        bail!("disk.raw has an invalid GPT partition-entry size");
+    }
+    let first_entry = entries_lba
+        .checked_mul(SECTOR_SIZE)
+        .context("GPT partition-entry offset overflow")? as usize;
+    let first_lba = pe_u64(&data, first_entry + 32, "GPT first partition LBA")?;
+    first_lba
+        .checked_mul(SECTOR_SIZE)
+        .context("GPT first partition offset overflow")
+}

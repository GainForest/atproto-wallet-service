{
  "name": "@gainforest/atproto-wallet-service",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "description": "Standalone, TEE-hosted embedded-wallet service for AT Protocol users on ANY PDS — 2-of-3 Shamir shares, user-signed envelopes, service-auth enrollment, attested wallet-binding records.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@atproto/crypto": "^0.4.5",
    "@atproto/identity": "^0.4.12",
    "@atproto/xrpc-server": "^0.10.14",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@phala/dstack-sdk": "0.5.8",
    "@scure/bip32": "^1.7.0",
    "@scure/bip39": "^1.6.0",
    "better-sqlite3": "12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ed25519-hd-key": "^1.3.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "jose": "^5.10.0",
    "pino": "^9.0.0",
    "shamir-secret-sharing": "^0.0.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "prettier": "^3.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.0"
  }
}
